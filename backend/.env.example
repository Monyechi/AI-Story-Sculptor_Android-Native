# Backend-owned secrets (never commit real values)
# Copy to backend/.env (or deployment secret manager) and populate.

# Provider credentials used by /api/v1/mobile/ai/* proxy endpoints.
OPENAI_API_KEY=sk-your-openai-api-key

# Optional provider defaults used by backend routing.
OPENAI_DEFAULT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Mobile backend API origin used by Android BuildConfig.BASE_URL.
API_PUBLIC_BASE_URL=https://api.example.com/
