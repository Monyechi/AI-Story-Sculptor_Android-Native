<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AIStorySculptor" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- White semi-transparent status bar -->
        <item name="android:statusBarColor" tools:targetApi="lollipop">#33FFFFFF</item>
        <item name="android:navigationBarColor">#FF2C3F2C</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <!-- Enable edge-to-edge content -->
        <item name="android:windowDrawsSystemBarBackgrounds" tools:targetApi="lollipop">true</item>
    </style>
</resources>
